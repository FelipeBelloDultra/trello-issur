# App
NODE_ENV=development
INSTANCE_ID=   # defaults to os.hostname(); set to POD_NAME in Kubernetes

# Logging
LOG_LEVEL=info

# Tracing
OTEL_ENDPOINT=   # e.g. http://otel-collector:4318/v1/traces — omit to disable tracing

# HTTP server
HTTP_SERVER_PORT=3000

# CORS
CORS_ORIGIN=https://yourdomain.com   # comma-separated origins, or * for dev only

# Auth
JWT_SECRET=   # min 32 chars; generate with: openssl rand -hex 32
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Valkey
VALKEY_URL=redis://localhost:6379

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_POOL_MAX=10          # reduce per instance when running multiple replicas (e.g. 100 / replica_count)
DB_IDLE_TIMEOUT=30     # seconds before an idle connection is closed; 0 = never
DB_CONNECT_TIMEOUT=10  # seconds to wait for a free connection before failing

# Queue (RabbitMQ)
RABBITMQ_URL=amqp://guest:guest@localhost:5672   # use amqps:// in production
RABBITMQ_PREFETCH=10   # number of unacked messages per consumer; tune per worker capacity
