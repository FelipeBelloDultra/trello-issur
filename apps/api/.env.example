# App
NODE_ENV=development
INSTANCE_ID=   # defaults to os.hostname(); set to POD_NAME in Kubernetes

# Logging
LOG_LEVEL=info

# Tracing
OTEL_ENDPOINT=   # e.g. http://otel-collector:4318/v1/traces — omit to disable tracing

# HTTP server
HTTP_SERVER_PORT=3000
APP_URL=http://localhost:3000

# CORS
CORS_ORIGIN=https://yourdomain.com   # comma-separated origins, or * for dev only

# Auth
JWT_SECRET=   # min 32 chars; generate with: openssl rand -hex 32
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Valkey
VALKEY_URL=redis://localhost:6379

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_POOL_MAX=10          # reduce per instance when running multiple replicas (e.g. 100 / replica_count)
DB_IDLE_TIMEOUT=30     # seconds before an idle connection is closed; 0 = never
DB_CONNECT_TIMEOUT=10  # seconds to wait for a free connection before failing

# Queue (RabbitMQ)
RABBITMQ_URL=amqp://guest:guest@localhost:5672   # use amqps:// in production
RABBITMQ_PREFETCH=10   # number of unacked messages per consumer; tune per worker capacity

# Email (SMTP)
SMTP_HOST=localhost
SMTP_PORT=1025          # 1025 for Mailpit (dev); 465 or 587 for production
SMTP_USER=              # empty for Mailpit; required for production SMTP
SMTP_PASS=              # empty for Mailpit; required for production SMTP
SMTP_FROM=noreply@trello-issur.dev

# Storage
STORAGE_DRIVER=local    # local | s3
STORAGE_LOCAL_PATH=./uploads            # filesystem path for the local adapter
STORAGE_LOCAL_BASE_URL=http://localhost:3000/uploads  # base URL served to clients

# S3 / MinIO (all required when STORAGE_DRIVER=s3)
S3_BUCKET=              # bucket name
S3_REGION=us-east-1     # AWS region; any value works for MinIO
S3_ENDPOINT=            # custom endpoint (e.g. http://localhost:9000 for MinIO); omit for real S3
S3_ACCESS_KEY=          # AWS access key ID or MinIO root user
S3_SECRET_KEY=          # AWS secret access key or MinIO root password
S3_PUBLIC_URL=          # base URL for generated file URLs (e.g. https://cdn.example.com or http://localhost:9000/bucket)
