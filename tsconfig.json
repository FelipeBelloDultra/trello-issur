{
    "extends": "@tsconfig/node24/tsconfig.json",
    "compilerOptions": {
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "jsx": "react-jsx",
        "outDir": "./dist",
        "types": ["@types/node", "vitest/globals"],
        "paths": {
            "@/*": ["./src/*"],
            "@/test/*": ["./test/*"]
        }
    }
}
